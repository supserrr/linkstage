{
  "hosting": {
    "public": "hosting_public",
    "ignore": [
      "firebase.json",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      },
      {
        "source": "/.well-known/assetlinks.json",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "linkstage-rw",
          "appId": "1:776691693274:android:96f51eacbba82152f0d7e3",
          "fileOutput": "android/app/google-services.json"
        },
        "buildConfigurations": {
          ".": {
            "projectId": "linkstage-rw",
            "appId": "1:776691693274:android:96f51eacbba82152f0d7e3",
            "fileOutput": "android/app/google-services.json"
          }
        }
      },
      "web": {
        "default": {
          "projectId": "linkstage-rw",
          "appId": "1:776691693274:web:ed4632f7936f009bf0d7e3"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "linkstage-rw",
          "configurations": {
            "android": "1:776691693274:android:96f51eacbba82152f0d7e3"
          }
        }
      },
      "ios": {
        "default": {
          "projectId": "linkstage-rw",
          "appId": "1:776691693274:ios:24c035d2b80939fef0d7e3",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "linkstage-rw",
          "appId": "1:776691693274:ios:24c035d2b80939fef0d7e3",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      }
    }
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "LinkStage",
        "supportEmail": "support@linkstage.app"
      }
    }
  }
}
